# Choose your AI backend
USE_GROQ=false                   # set to true to use Groq cloud API
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama3-8b-8192

# Ollama (local AI — default)
OLLAMA_MODEL=llama3.2            # or phi3, mistral, qwen2.5-coder

# Twilio WhatsApp (for attendance alerts)
TWILIO_ACCOUNT_SID=your_sid
TWILIO_AUTH_TOKEN=your_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Supabase (database — replace in-memory store for prod)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# CORS — comma-separated origins
ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com
